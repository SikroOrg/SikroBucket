    "hash": "5caa031fec4f7df536c561c3664c243e43bcb475573be792ae1cad04f214052b",
    "extract_dir": "v2rayN-Core",
    "pre_install": [
        "# 'guiNConfig.json',",
        "if (Test-Path \"$persist_dir\\guiNConfig.json\") {",
        "    Copy-Item \"$persist_dir\\guiNConfig.json\" \"$dir\\\" | Out-Null",
        "}",
        "Invoke-WebRequest \"https://gh.sikro.cf/https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat\" -OutFile $dir\\geoip.dat",
        "Invoke-WebRequest \"https://gh.sikro.cf/https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geosite.dat\" -OutFile $dir\\geosite.dat"
    ],
    "uninstaller": {
        "script": [
            "if (Test-Path \"$dir\\guiNConfig.json\") {",
            "    Copy-Item \"$dir\\guiNConfig.json\" \"$persist_dir\\\" | Out-Null",
            "}"
        ]
    },
    "bin": "v2rayN.exe",
    "shortcuts": [
        [
            "v2rayN.exe",
            "v2rayN"
        ]
    ],
    "persist": [
        "geoip.dat",
        "geosite.dat"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/2dust/v2rayN/releases",
        "jsonpath": "$.[0].tag_name"
    },
    "autoupdate": {
        "url": "https://gh.sikro.cf/https://github.com/2dust/v2rayN/releases/download/$version/v2rayN-Core.zip"
    }
